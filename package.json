{
  "name": "@manulife-portfolio-dashboard/source",
  "version": "0.1.0",
  "license": "MIT",
  "scripts": {
    "nx": "nx",
    "lint": "pnpm nx run-many --target=lint --all",
    "format": "prettier --write .",
    "test": "pnpm nx run-many --target=test --all",
    "test:ci": "pnpm nx run-many --target=test --all --coverage",
    "build": "pnpm nx run-many --target=build --all --configuration=production",
    "dev:api": "pnpm nx serve api",
    "dev:web": "pnpm nx serve web",
    "dev": "pnpm nx run-many --target=serve --projects=api,web",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "db:migrate": "prisma migrate dev --schema apps/api/prisma/schema.prisma",
    "db:generate": "prisma generate --schema apps/api/prisma/schema.prisma",
    "db:studio": "prisma studio --schema apps/api/prisma/schema.prisma"
  },
  "prisma": {
    "seed": "node --experimental-strip-types apps/api/prisma/seed.ts",
    "schema": "apps/api/prisma/schema.prisma"
  },
  "private": true,
  "packageManager": "pnpm@10.17.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "bcrypt",
      "prisma"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/eslint": "23.0.0",
