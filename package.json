    "@nx/nest": "23.0.0",
    "@nx/node": "23.0.0",
    "@nx/react": "23.0.0",
    "@nx/vite": "23.0.0",
    "@nx/vitest": "23.0.0",
    "@nx/web": "23.0.0",
    "@nx/webpack": "23.0.0",
    "@nx/workspace": "23.0.0",
    "@swc/cli": "~0.8.0",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@testing-library/dom": "10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "16.3.0",
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "~30.0.0",
    "@types/node": "^22.19.21",
    "@types/passport": "^1.0.17",
